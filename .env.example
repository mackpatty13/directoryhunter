# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (required for db.js and any script with --store)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic (required for discovery scoring and deep evaluation)
ANTHROPIC_API_KEY=

# Reddit (User-Agent identifies the scanner per Reddit's API rules)
REDDIT_USERNAME=

# Google Places API (paid past the $200/month free credit; used in evaluation
# and the weekly category sampler). Get a key from the Google Cloud console,
# enable the "Places API (New)" service, then create an API key and restrict
# it to that API.
GOOGLE_PLACES_API_KEY=

# DataforSEO (paid, used in evaluation only; use sandbox creds during dev)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_SANDBOX=true

# Resend (Sunday digest email; sender is hunter@buildmyblast.com)
RESEND_API_KEY=
DIGEST_RECIPIENT_EMAIL=

# App
APP_BASE_URL=http://localhost:3000
